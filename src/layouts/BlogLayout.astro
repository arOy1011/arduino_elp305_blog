---
import '../styles/blog.css';
const { frontmatter } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter?.title ?? 'Blog Post'}</title>
  </head>

  <body>
    <main class="content">
      <nav class="blog-nav">
        <a href="/blog">Other Blogs</a>
        {frontmatter?.github && (
          <a href={frontmatter.github} target="_blank" rel="noopener noreferrer">
            GitHub
          </a>
        )}
        <a href="https://your-portfolio-domain.com" target="_blank" rel="noopener noreferrer">
          About Author
        </a>
      </nav>

      <h1>{frontmatter?.title}</h1>
      <slot />

    </main>
  </body>
</html>

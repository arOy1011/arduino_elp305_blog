---
import './blog.css';
const { frontmatter } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter.title}</title>
    <meta name="description" content={frontmatter.description} />
  </head>

  <body>
    <nav class="navbar">
      <div class="nav-content">
        <a href="/" class="brand">Arduino learning Blog [ELP 305]</a>
        <div class="nav-links">
          <a href="/">Other Blogs</a>
          <a href="https://github.com/arOy1011/2026_GIPDEI_ARNAB_ROY">GitHub</a>
        </div>
      </div>
    </nav>

    <header class="hero">
      <div class="hero-content">
        <span class="badge">Embedded Systems • Arduino • Electronics</span>
        <h1>{frontmatter.title}</h1>
        {frontmatter.description && <p>{frontmatter.description}</p>}
        <div class="meta">
          <span>Arduino Learning • Embedded Systems</span>
          <span>•</span>
          <span>Lab Documentation & Projects</span>
        </div>
      </div>
    </header>

    <main class="container">
      <article class="content">
        <slot />
      </article>
    </main>

    <footer class="footer">
      <p>Built with Astro • Electronics & Embedded Systems Portfolio</p>
    </footer>
  </body>
</html>
